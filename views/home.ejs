<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Dashboard – Snip</title>
  <link rel="icon" type="image/png" href="/favicon.png">
  <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;500;600;700&family=Inter:wght@400;500&display=swap" rel="stylesheet">
  <style>
    *,
    *::before,
    *::after {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
    }

    body {
      font-family: 'Inter', Arial, sans-serif;
      background: radial-gradient(circle at 50% 0%, #1e1b4b 0%, #09090b 100%);
      min-height: 100vh;
      display: flex;
      flex-direction: column;
      align-items: center;
      padding: 48px 16px;
      color: #e2e8f0;
      position: relative;
    }

    /* Ambient glow */
    body::before {
      content: "";
      position: absolute;
      width: 500px;
      height: 500px;
      background: radial-gradient(circle, rgba(124, 110, 245, 0.1) 0%, transparent 70%);
      top: -150px;
      left: 10%;
      z-index: 0;
      pointer-events: none;
    }

    .container {
      width: 100%;
      max-width: 600px;
      z-index: 10;
    }

    .topbar {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 32px;
    }

    .brand {
      display: flex;
      align-items: center;
      gap: 10px;
    }

    .brand-logo {
      width: 32px;
      height: 32px;
      object-fit: contain;
      filter: drop-shadow(0 0 6px rgba(124, 110, 245, 0.3));
    }

    .brand-name {
      font-family: 'Outfit', sans-serif;
      font-size: 20px;
      font-weight: 700;
      color: #fff;
      letter-spacing: -0.5px;
    }

    .welcome-chip {
      font-size: 13.5px;
      color: #cbd5e1;
      background: rgba(255, 255, 255, 0.03);
      border: 1px solid rgba(255, 255, 255, 0.08);
      padding: 6px 14px;
      border-radius: 999px;
      display: flex;
      align-items: center;
      gap: 12px;
    }

    .logout-btn {
      background: none;
      border: none;
      color: #64748b;
      font-size: 13px;
      font-weight: 500;
      cursor: pointer;
      font-family: inherit;
      transition: color 0.15s;
      text-decoration: none;
    }

    .logout-btn:hover {
      color: #f87171;
    }

    .card {
      background: rgba(22, 22, 30, 0.65);
      backdrop-filter: blur(20px) saturate(140%);
      -webkit-backdrop-filter: blur(20px) saturate(140%);
      border: 1px solid rgba(124, 110, 245, 0.18);
      border-radius: 20px;
      width: 100%;
      box-shadow: 0 12px 40px rgba(0, 0, 0, 0.45);
      overflow: hidden;
    }

    .card-section {
      padding: 28px 32px;
      border-bottom: 1px solid rgba(255, 255, 255, 0.05);
    }

    .card-section:last-child {
      border-bottom: none;
    }

    .section-label {
      font-family: 'Outfit', sans-serif;
      font-size: 12px;
      font-weight: 600;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: #64748b;
      margin-bottom: 18px;
    }

    .url-list {
      list-style: none;
      display: flex;
      flex-direction: column;
      gap: 12px;
      max-height: 320px;
      overflow-y: auto;
      scrollbar-width: thin;
      scrollbar-color: rgba(124, 110, 245, 0.3) transparent;
      padding-right: 4px;
    }

    /* Custom scrollbar for list container */
    .url-list::-webkit-scrollbar {
      width: 6px;
    }

    .url-list::-webkit-scrollbar-track {
      background: transparent;
    }

    .url-list::-webkit-scrollbar-thumb {
      background: rgba(124, 110, 245, 0.3);
      border-radius: 99px;
    }

    .url-item {
      background: rgba(0, 0, 0, 0.2);
      border: 1px solid rgba(255, 255, 255, 0.05);
      border-radius: 12px;
      padding: 16px 20px;
      transition: all 0.2s ease;
    }

    .url-item:hover {
      border-color: rgba(124, 110, 245, 0.3);
      background: rgba(124, 110, 245, 0.03);
      transform: translateX(2px);
    }

    .url-top {
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 16px;
    }

    .url-content {
      flex: 1;
      min-width: 0;
    }

    .short-link {
      font-size: 14.5px;
      font-weight: 600;
      color: #818cf8;
      text-decoration: none;
      display: block;
      margin-bottom: 6px;
      transition: color 0.15s;
      word-break: break-all;
    }

    .short-link:hover {
      color: #c7d2fe;
    }

    .original-url {
      font-size: 12.5px;
      color: #64748b;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }

    .meta-row {
      display: flex;
      align-items: center;
      gap: 12px;
      font-size: 12px;
      color: #475569;
      margin-top: 10px;
      padding-top: 10px;
      border-top: 1px solid rgba(255, 255, 255, 0.03);
    }

    .clicks-badge {
      background: rgba(124, 110, 245, 0.1);
      color: #a5b4fc;
      padding: 2px 8px;
      border-radius: 999px;
      font-weight: 500;
    }

    .analytics-link {
      color: #7c6ef5;
      text-decoration: none;
      font-weight: 600;
      transition: color 0.15s;
    }

    .analytics-link:hover {
      color: #c7d2fe;
    }

    .delete-btn {
      background: rgba(239, 68, 68, 0.08);
      border: 1px solid rgba(239, 68, 68, 0.15);
      color: #f87171;
      padding: 8px 14px;
      border-radius: 8px;
      font-size: 12.5px;
      font-weight: 500;
      cursor: pointer;
      font-family: inherit;
      transition: all 0.2s ease;
    }

    .delete-btn:hover {
      background: rgba(239, 68, 68, 0.2);
      border-color: rgba(239, 68, 68, 0.4);
      color: #fff;
    }

    .empty-state {
      text-align: center;
      padding: 32px 0;
      color: #475569;
      font-size: 14.5px;
    }

    .input-row {
      display: flex;
      gap: 12px;
    }

    .url-input {
      flex: 1;
      background: rgba(0, 0, 0, 0.25);
      border: 1px solid rgba(255, 255, 255, 0.08);
      border-radius: 12px;
      padding: 14px 18px;
      font-size: 14.5px;
      color: #e2e8f0;
      font-family: inherit;
      outline: none;
      transition: all 0.2s ease;
    }

    .url-input::placeholder {
      color: #475569;
    }

    .url-input:focus {
      border-color: #7c6ef5;
      box-shadow: 0 0 0 3px rgba(124, 110, 245, 0.18);
      background: rgba(0, 0, 0, 0.35);
    }

    .submit-btn {
      background: linear-gradient(135deg, #7c6ef5 0%, #6366f1 100%);
      color: #fff;
      border: none;
      border-radius: 12px;
      padding: 14px 24px;
      font-size: 14.5px;
      font-weight: 600;
      cursor: pointer;
      font-family: inherit;
      white-space: nowrap;
      transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
      box-shadow: 0 4px 14px rgba(124, 110, 245, 0.25);
    }

    .submit-btn:hover {
      transform: translateY(-1px);
      box-shadow: 0 6px 20px rgba(124, 110, 245, 0.45);
      background: linear-gradient(135deg, #8a7df6 0%, #4f46e5 100%);
    }

    .error-box {
      background: rgba(239, 68, 68, 0.1);
      border: 1px solid rgba(239, 68, 68, 0.25);
      border-radius: 12px;
      padding: 12px 16px;
      font-size: 13.5px;
      color: #f87171;
      margin-bottom: 20px;
    }

    @media (max-width: 600px) {
      .input-row {
        flex-direction: column;
      }

      .submit-btn {
        width: 100%;
      }

      .topbar {
        flex-direction: column;
        gap: 16px;
        align-items: flex-start;
      }
    }
  </style>
</head>

<body>

  <div class="container">
    <div class="topbar">
      <div class="brand">
        <img src="/favicon.png" alt="Snip Logo" class="brand-logo">
        <span class="brand-name">Snip</span>
      </div>

      <% if (locals.user) { %>
      <div class="welcome-chip">
        <span><%= user.name %></span>
        <a href="/user/logout" class="logout-btn">Logout</a>
      </div>
      <% } %>
    </div>

    <div class="card">

      <div class="card-section">
        <p class="section-label">Your links</p>

        <% if (allURLs && allURLs.length > 0) { %>
        <ul class="url-list">
          <% allURLs.forEach(url => { %>
          <li class="url-item">
            <div class="url-top">
              <div class="url-content">
                <a href="/<%= url.shortId %>" class="short-link" target="_blank">
                  https://snip.beingbifrons.shop/<%= url.shortId %>
                </a>
                <div class="original-url">
                  → <%= url.redirectURL %>
                </div>
                <div class="meta-row">
                  <span class="clicks-badge">Clicks: <%= url.clickCount || 0 %></span>
                  <span>•</span>
                  <a href="/dashboard/analytics/<%= url.shortId %>" class="analytics-link">View Analytics</a>
                </div>
              </div>

              <form action="/urls/delete/<%= url._id %>" method="POST" onsubmit="return confirm('Are you sure you want to delete this URL?')">
                <button class="delete-btn" type="submit">Delete</button>
              </form>
            </div>
          </li>
          <% }) %>
        </ul>
        <% } else { %>
        <p class="empty-state">No links shortened yet. Paste a link below to get started!</p>
        <% } %>
      </div>

      <div class="card-section">
        <p class="section-label">Shorten a URL</p>

        <% if (locals.error) { %>
        <div class="error-box">
          <%= error %>
        </div>
        <% } %>

        <form action="/urls" method="POST">
          <div class="input-row">
            <input class="url-input" type="text" name="url" placeholder="https://example.com/very-long-link" required autocomplete="off">
            <button class="submit-btn" type="submit">Shorten link</button>
          </div>
        </form>
      </div>

    </div>
  </div>

</body>

</html>