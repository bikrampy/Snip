<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Dashboard – Snip</title>

  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&display=swap" rel="stylesheet">

  <style>
    *,
    *::before,
    *::after {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
    }

    body {
      font-family: 'Inter', Arial, sans-serif;
      background: #0f0f11;
      min-height: 100vh;
      display: flex;
      flex-direction: column;
      align-items: center;
      padding: 48px 16px;
      color: #e8e8f0;
    }

    .topbar {
      width: 100%;
      max-width: 560px;
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 32px;
    }

    .brand {
      font-size: 20px;
      font-weight: 600;
      color: #fff;
      letter-spacing: -0.4px;
      display: flex;
      align-items: center;
      gap: 8px;
    }

    .brand-dot {
      width: 8px;
      height: 8px;
      border-radius: 50%;
      background: #7c6ef5;
    }

    .welcome-chip {
      font-size: 13px;
      color: #9898b0;
      background: #1c1c24;
      padding: 6px 14px;
      border-radius: 999px;
      border: 1px solid #2a2a38;
      display: flex;
      align-items: center;
      gap: 10px;
    }

    .logout-btn {
      background: none;
      border: none;
      color: #5a5a78;
      font-size: 13px;
      cursor: pointer;
      padding: 0;
      font-family: inherit;
      transition: color 0.15s;
    }

    .logout-btn:hover {
      color: #e8e8f0;
    }

    .card {
      background: #16161e;
      border: 1px solid #2a2a38;
      border-radius: 16px;
      width: 100%;
      max-width: 560px;
      overflow: hidden;
    }

    .card-section {
      padding: 24px 28px;
      border-bottom: 1px solid #1f1f2b;
    }

    .card-section:last-child {
      border-bottom: none;
    }

    .section-label {
      font-size: 11px;
      font-weight: 600;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: #5a5a78;
      margin-bottom: 16px;
    }

    .url-list {
      list-style: none;
      display: flex;
      flex-direction: column;
      gap: 10px;
      max-height: 260px;
      overflow-y: auto;
      scrollbar-width: thin;
      scrollbar-color: #2a2a38 transparent;
    }

    .url-item {
      background: #1c1c24;
      border: 1px solid #2a2a38;
      border-radius: 10px;
      padding: 14px 16px;
      display: flex;
      flex-direction: column;
      gap: 10px;
    }

    .url-top {
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      gap: 12px;
    }

    .url-content {
      flex: 1;
      min-width: 0;
    }

    .short-link {
      font-size: 13px;
      font-weight: 500;
      color: #7c6ef5;
      text-decoration: none;
      display: block;
      margin-bottom: 4px;
      transition: color 0.15s;
      word-break: break-all;
    }

    .short-link:hover {
      color: #a89cf7;
    }

    .original-url {
      font-size: 12px;
      color: #5a5a78;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }

    .delete-form {
      flex-shrink: 0;
    }

    .delete-btn {
      background: #2a1f24;
      border: 1px solid #44252f;
      color: #ff7a90;
      padding: 8px 12px;
      border-radius: 8px;
      font-size: 12px;
      cursor: pointer;
      font-family: inherit;
      transition: all 0.15s;
    }

    .delete-btn:hover {
      background: #3a232c;
      border-color: #5e2e3c;
      color: #ff9bad;
    }

    .empty-state {
      text-align: center;
      padding: 12px 0;
      color: #5a5a78;
      font-size: 14px;
    }

    .input-row {
      display: flex;
      gap: 10px;
    }

    .url-input {
      flex: 1;
      background: #1c1c24;
      border: 1px solid #2a2a38;
      border-radius: 10px;
      padding: 12px 16px;
      font-size: 14px;
      color: #e8e8f0;
      font-family: inherit;
      outline: none;
      transition: border-color 0.15s;
    }

    .url-input::placeholder {
      color: #3a3a50;
    }

    .url-input:focus {
      border-color: #7c6ef5;
    }

    .submit-btn {
      background: #7c6ef5;
      color: #fff;
      border: none;
      border-radius: 10px;
      padding: 12px 20px;
      font-size: 14px;
      font-weight: 500;
      cursor: pointer;
      font-family: inherit;
      white-space: nowrap;
      transition: background 0.15s;
    }

    .submit-btn:hover {
      background: #6a5de0;
    }

    @media (max-width: 600px) {
      .input-row {
        flex-direction: column;
      }

      .submit-btn {
        width: 100%;
      }

      .url-top {
        flex-direction: column;
      }

      .delete-form {
        width: 100%;
      }

      .delete-btn {
        width: 100%;
      }

      .topbar {
        flex-direction: column;
        gap: 16px;
        align-items: flex-start;
      }
    }
  </style>
</head>

<body>

  <div class="topbar">
    <div class="brand">
      <div class="brand-dot"></div>
      Snip
    </div>

    <% if (user) { %>
    <div class="welcome-chip">
      <span><%= user.name %></span>

      <a href="/user/logout" style="text-decoration:none;">
        <button class="logout-btn">Logout</button>
      </a>
    </div>
    <% } %>
  </div>

  <div class="card">

    <div class="card-section">
      <p class="section-label">Your links</p>

      <% if (allURLs.length > 0) { %>

      <ul class="url-list">

        <% allURLs.forEach(url => { %>

        <li class="url-item">

          <div class="url-top">

            <div class="url-content">
              <a href="/<%= url.shortId %>" class="short-link">
                http://localhost:8001/<%= url.shortId %>
              </a>

              <div class="original-url">
                → <%= url.redirectURL %>
              </div>
            </div>

            <form class="delete-form" action="/urls/delete/<%= url._id %>" method="POST" onsubmit="return confirm('Are you sure you want to delete this URL?')">
              <button class="delete-btn" type="submit">
                Delete
              </button>
            </form>

          </div>

        </li>

        <% }) %>

      </ul>

      <% } else { %>

      <p class="empty-state">
        No links yet. Create one below.
      </p>

      <% } %>
    </div>

    <div class="card-section">
      <p class="section-label">Shorten a URL</p>

      <form action="/urls" method="POST">

        <div class="input-row">

          <input class="url-input" type="text" name="url" placeholder="https://example.com" required>

          <button class="submit-btn" type="submit">
            Shorten
          </button>

        </div>

      </form>
    </div>

  </div>

</body>

</html>